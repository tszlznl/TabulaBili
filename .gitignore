# ==========================================
# 1. Chrome Extension Build Artifacts
# ==========================================
# Chrome 打包自动生成的数字签名文件夹
_metadata/

# 打包生成的二进制安装包
*.crx

# 打包生成的私钥证书文件 (⚠️ 极其重要，绝不能泄露或提交到 Git)
*.pem

# ==========================================
# 2. Operating System Files
# ==========================================
# macOS 系统缓存文件
.DS_Store
.AppleDouble
.LSOverride
Icon

# Windows 系统缓存文件
Thumbs.db
ehthumbs.db
Desktop.ini

# ==========================================
# 3. Editor & IDE Configurations
# ==========================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ==========================================
# 4. Logs & Temp Files
# ==========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.temp/
.tmp/
